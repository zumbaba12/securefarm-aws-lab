# Copy this file to /etc/securefarm.env on the EC2 instance.
#
# Production mode hides the demo-credential helper endpoint/UI. The lab
# vulnerabilities intentionally remain present in this first deployment.
NODE_ENV=production
HOST=127.0.0.1
PORT=4000
SECUREFARM_DB=/var/lib/securefarm/securefarm.sqlite

# S3 plot uploads. No AWS access keys go here: the app uses the AWS SDK default
# provider chain, which resolves to the attached EC2 instance role. Only the
# region and (optional) bucket/prefix/size overrides are configured.
AWS_REGION=ap-southeast-2
SECUREFARM_UPLOAD_BUCKET=securefarm-uploads-1111
SECUREFARM_UPLOAD_PREFIX=plot-uploads
SECUREFARM_UPLOAD_MAX_BYTES=5242880
